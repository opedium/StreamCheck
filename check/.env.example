# =============================================
# Bilibili Video Upload Checker Configuration
# =============================================
# Copy this file to .env and fill in your values:
#   copy .env.example .env

# Required: Comma-separated Bilibili member IDs to monitor
# Find these in the URL: https://space.bilibili.com/{mid}
BILI_MIDS=2012055556

# Required: Weibo web cookie for posting notifications
# Get this from your browser's cookies when logged into weibo.com
WEIBO_COOKIE=your_weibo_cookie_here

# Optional: Bilibili cookie (helps avoid anti-bot 412 errors)
# Get this from your browser's cookies when logged into bilibili.com
BILI_COOKIE=

# Optional: Check interval in seconds (default: 300 = 5 minutes)
CHECK_INTERVAL=300

# Optional: Custom Weibo notification template
# Available variables:
#   {name}    - Uploader's nickname
#   {title}   - Video title
#   {bvid}    - Video BV ID
#   {aid}     - Video AV ID
#   {created} - Upload timestamp
#   {mid}     - Uploader's member ID
WEIBO_TEMPLATE=【B站更新】{name} 发布了新视频：{title} https://www.bilibili.com/video/{bvid}

# Optional: Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
