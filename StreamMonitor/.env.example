# =============================================
# StreamMonitor Configuration
# =============================================
# Copy this file to .env and fill in your values:
#   copy .env.example .env

# Required: Douyin cookie for accessing live stream info
# You can use DY_LIVE_COOKIES (preferred) or DY_COOKIES
# Get these from your browser's cookies when logged into douyin.com
DY_LIVE_COOKIES='your_douyin_cookie_here'

# Required: Weibo web cookie for posting notifications
# Get this from your browser's cookies when logged into weibo.com
WEIBO_COOKIE='your_weibo_cookie_here'

# Required: Douyin live room ID (the number in live.douyin.com/{live_id})
DY_LIVE_ID='your_live_room_id'

# Optional: Live room title (used in templates)
DY_LIVE_TITLE=''

# Optional: Check interval in seconds (default: 60)
CHECK_INTERVAL=60

# Optional: Custom Weibo templates
# Available variables for LIVE_TEMPLATE:
#   {name}    - Streamer's nickname
#   {title}   - Live room title
#   {live_id} - Live room ID
#   {room_id} - Internal room ID
LIVE_TEMPLATE='{name} 开播了！快来围观吧！'

# Available variables for OFFLINE_SUMMARY_TEMPLATE:
#   {name}      - Streamer's nickname
#   {views}     - Total views (场观) in 万 format
#   {likes}     - Total likes in 万 format
#   {peak}      - Peak concurrent viewers in 万 format
#   {avg}       - Average concurrent viewers in 万 format
#   {followers} - New followers count (raw number)
#   {members}   - New fan club members (raw number)
#   {badges}    - Light badges count (raw number)
#   {gifts}     - Top gifts summary
#   {duration}  - Stream duration (e.g. "1小时23分钟")
# NOTE: Use \n for newlines. Write the template in a single .env line.
# Example: {name} 直播结束\n场观：{views}\n点赞：{likes}\n最高在线：{peak}
OFFLINE_SUMMARY_TEMPLATE={name} 直播结束\n场观：{views}\n点赞：{likes}\n最高在线：{peak}\n平均在线：{avg}\n新增粉丝：{followers}\n新增粉丝团：{members}\n点亮灯牌：{badges}\n热门礼物：{gifts}\n直播时长：{duration}

# =============================================
# Cookie Refresh & Health Alerts
# =============================================

# Optional: Telegram bot for cookie health alerts
# Create a bot via @BotFather on Telegram, then get your chat ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: Cookie refresh interval in seconds (default: 21600 = 6 hours)
COOKIE_REFRESH_INTERVAL=21600